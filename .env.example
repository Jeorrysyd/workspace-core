# === AI Provider (Required) ===
# Which AI backend to use:
#   claude-cli    — Uses your Claude Code subscription (default, no API key needed)
#   anthropic-api — Uses Anthropic API directly (requires ANTHROPIC_API_KEY)
#   openai-api    — Uses OpenAI API (requires OPENAI_API_KEY, community-maintained)
AI_PROVIDER=claude-cli

# API keys — only needed for the provider you chose above
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: override the Anthropic model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === App Config ===
PORT=3456
APP_NAME=AI Workspace
OWNER_NAME=User

# Path to your markdown notes folder (Obsidian vault, Logseq, or any folder of .md files)
# NOTES_DIR=~/path/to/your/notes

# Path to podcast-analyze project (optional, enables podcast room)
# PODCAST_DIR=~/path/to/podcast-analyze

# Path to local Whisper model (optional, enables audio transcription)
# WHISPER_MODEL=~/tools/ggml-large-v3-turbo-q5_0.bin
