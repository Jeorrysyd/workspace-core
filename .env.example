# ============================================
# workspace-core 配置文件
# 复制这个文件为 .env，然后填入你的设置
# cp .env.example .env
# ============================================

# ====== AI 设置（必填）======

# 选择 AI 服务供应商
# 选项：anthropic-api（推荐）/ claude-cli
AI_PROVIDER=anthropic-api

# Anthropic API Key（选了 anthropic-api 就必须填这个）
# 获取方式：
#   1. 去 https://console.anthropic.com 注册/登录
#   2. 点左侧 "API Keys"
#   3. 点 "Create Key"
#   4. 复制生成的 key（以 sk-ant- 开头，很长一串）
# 格式示例：sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx（不是真的 key，只是告诉你长什么样）
ANTHROPIC_API_KEY=在这里粘贴你的key

# ====== 基本设置 ======

# 服务端口（一般不用改）
PORT=3456

# 工作台显示名称（显示在页面左上角）
APP_NAME=AI 工作台

# 你的名字（AI 对话时会用到）
OWNER_NAME=用户

# ====== 笔记设置（可选）======

# 你的 Markdown 笔记文件夹路径
# 支持 Obsidian、Logseq、或任何放 .md 文件的文件夹
# Mac 示例：  NOTES_DIR=~/Documents/我的笔记
# Windows：   NOTES_DIR=C:/Users/你的用户名/Documents/笔记
# 不填的话，档案馆房间会是空的（其他房间正常用）
# NOTES_DIR=

# ====== 进阶设置（可选，不填也能用）======

# Anthropic 模型选择（一般不用改，默认用最新的）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
