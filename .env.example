# ============================================
# workspace-core — AI Content Pipeline
# 复制这个文件为 .env，然后填入你的设置
# cp .env.example .env
# ============================================

# ====== AI 设置（必填）======

# 选择 AI 服务供应商
# 选项：anthropic-api（推荐）/ claude-cli
AI_PROVIDER=anthropic-api

# Anthropic API Key（选了 anthropic-api 就必须填这个）
# 获取方式：https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=在这里粘贴你的key

# ====== 基本设置 ======

# 服务端口
PORT=3456

# 应用名称（显示在页面左上角）
APP_NAME=AI Content Pipeline

# 你的名字（AI 会用这个名字来个性化内容）
OWNER_NAME=用户

# ====== 笔记设置（可选）======

# 你的 Markdown 笔记文件夹路径
# 支持 Obsidian、Logseq、或任何放 .md 文件的文件夹
# Pipeline 的"发现"步骤会扫描这里的笔记来寻找选题灵感
# Mac 示例：  NOTES_DIR=~/Documents/我的笔记
# Windows：   NOTES_DIR=C:/Users/你的用户名/Documents/笔记
# NOTES_DIR=

# ====== 外部信息源（可选）======

# 外部 feed 数据的 URL 前缀
# Pipeline 的"发现"步骤会从这个地址拉取 feed-x.json、feed-podcasts.json 等
# 不设置则"外部信息源"功能不可用（其他功能不受影响）
# FEED_BASE_URL=

# 或者用本地路径（优先级高于 FEED_BASE_URL）
# BUILDERS_FEED_PATH=

# ====== 进阶设置（可选）======

# Anthropic 模型选择
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
