{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "AI 工作台 (workspace-core)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["server/index.js"],
      "port": 3456,
      "autoPort": true,
      "env": {
        "PATH": "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "podcast-analyze-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "podcast-analyze (CLI)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 0
    }
  ]
}
